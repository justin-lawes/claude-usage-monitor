<Application x:Class="ClaudeUsageMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Dark theme colors matching macOS version -->
        <Color x:Key="BgColor">#1A1A1E</Color>
        <Color x:Key="CardBgColor">#222226</Color>
        <Color x:Key="DividerColor">#33FFFFFF</Color>
        <Color x:Key="TextPrimaryColor">#DDFFFFFF</Color>
        <Color x:Key="TextSecondaryColor">#66FFFFFF</Color>
        <Color x:Key="TextDimColor">#4DFFFFFF</Color>
        <Color x:Key="GreenColor">#40B87A</Color>
        <Color x:Key="YellowColor">#F2BF40</Color>
        <Color x:Key="OrangeColor">#F28C33</Color>
        <Color x:Key="RedColor">#E64040</Color>
        <Color x:Key="BlueColor">#738CBF</Color>

        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
        <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}" />
        <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}" />
    </Application.Resources>
</Application>
